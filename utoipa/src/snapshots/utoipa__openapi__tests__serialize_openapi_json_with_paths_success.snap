{
  "openapi": "3.2.0",
  "info": {
    "title": "My big api",
    "version": "1.1.0"
  },
  "paths": {
    "/api/v1/users": {
      "get": {
        "responses": {
          "200": {
            "description": "Get users list"
          }
        }
      },
      "post": {
        "responses": {
          "200": {
            "description": "Post new user"
          }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "Get user by id"
          }
        }
      }
    }
  }
}
